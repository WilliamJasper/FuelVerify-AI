# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า (ไฟล์ .env จะไม่ถูก commit)

# พอร์ต backend (ห้ามใช้ 8000 บนเครื่องนี้ — ชน ERP); IIS proxy /FuelVerifyAI/upload* -> 127.0.0.1:PORT
PORT=
HOST=

TYPHOON_API_KEY=changeme

# ไม่บังคับ
# TYPHOON_OCR_URL=https://api.opentyphoon.ai/v1/ocr
# เปิดเป็น 1 เพื่อบังคับแปลง PDF เป็น text-layer ก่อนส่งเข้า Typhoon ทุกครั้ง
# SLIP_FORCE_TEXT_LAYER=1

# Provider สำหรับแปลง text-layer ก่อน Typhoon: auto | ilovepdf | ocrmypdf
# auto = ใช้ ilovepdf เมื่อมี key, ไม่งั้นใช้ ocrmypdf
# SLIP_TEXTLAYER_PROVIDER=auto

# iLovePDF API (กรณีเลือกใช้ ilovepdf)
# ILOVEPDF_PUBLIC_KEY=changeme
# ILOVEPDF_SECRET_KEY=changeme
# ILOVEPDF_REGION=eu
