# พอร์ต backend (ห้ามใช้ 8000 บนเครื่องนี้ — ชน ERP)
PORT=
HOST=

# 1. Typhoon OCR (ตัวอ่านหลัก)
TYPHOON_API_KEY=

# 2. iLovePDF API (ตัวแปลง Text Layer)
# สมัครที่ https://developer.ilovepdf.com/
ILOVEPDF_PUBLIC_KEY=
ILOVEPDF_SECRET_KEY=
ILOVEPDF_REGION=eu

# ตั้งค่าให้ใช้ iLovePDF อัตโนมัติเมื่อมี Key
SLIP_TEXTLAYER_PROVIDER=auto

# จำนวนหน้าที่จะแสกนพร้อมกัน (ความเร็วเฉลี่ย 15-30 วินาที)
SLIP_OCR_WORKERS=2
